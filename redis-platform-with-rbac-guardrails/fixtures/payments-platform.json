      "id": "payments-api-secret-list-prod-us",
      "severity": "medium",
      "variant": "prod-us",
      "piece": "payments-api",
      "reason": "payments-api can list every Secret in payments-prod.",
      "recommendation": "Narrow the Role to get only the named runtime Secret before promoting to prod-eu.",
      "betterPlace": "derived prod-us variant unless every production variant needs the same rule"
