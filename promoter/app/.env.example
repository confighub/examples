# The ConfigHub instance this app talks to (browser-direct).
VITE_CONFIGHUB_BASE_URL=https://hub.confighub.com

# This app's registered OAuth client id. Register one for your dev origin
# (port 5181) and paste the id here:
#   cub oauthclient create promoter-dev --redirect-uri http://localhost:5181/
# Copy this file to .env.local (gitignored) and fill it in.
VITE_OAUTH_CLIENT_ID=
