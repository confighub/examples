#!/bin/bash

set -e

CLUSTER_NAME=${1:-gitops-import}
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

echo "Creating Kind cluster: $CLUSTER_NAME"

mkdir -p "$PROJECT_DIR/var"

kind create cluster \
  --name "$CLUSTER_NAME" \
  --config "$PROJECT_DIR/cluster/kind-config.yaml" \
  --kubeconfig "$PROJECT_DIR/var/$CLUSTER_NAME.kubeconfig"

echo "Cluster $CLUSTER_NAME created successfully"
echo "Kubeconfig saved to: $PROJECT_DIR/var/$CLUSTER_NAME.kubeconfig"

export KUBECONFIG="$PROJECT_DIR/var/$CLUSTER_NAME.kubeconfig"

echo "Waiting for cluster to be ready..."
kubectl wait --for=condition=Ready nodes --all --timeout=60s

echo "Cluster is ready!"
