#!/bin/bash

if [ ! -e ".example-name" ]; then
  echo "No .example-name file found. Can't clean up."
  exit 1
fi

name=$(cat .example-name)

cub space delete --where "Labels.ExampleName = '$name'" --recursive

if [ -e var/$name.kubeconfig ]; then
  echo "Deleting Kind cluster $name"
  kind delete cluster --name $name-infra
fi

rm -f var/$name.kubeconfig
rm -f .example-name

echo "Cleanup of $name-* spaces complete!"
