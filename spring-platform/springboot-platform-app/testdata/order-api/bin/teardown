#!/usr/bin/env bash
# Tear down the Kind cluster and stop the worker.
#
# Usage:
#   ./bin/teardown              # Teardown default cluster
#   ./bin/teardown my-cluster   # Teardown specified cluster
#   ./bin/teardown --keep-cluster  # Stop worker but keep cluster
#
# This will:
#   - Stop the ConfigHub worker process
#   - Delete the Kind cluster
#   - Clean up state files in var/

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "${SCRIPT_DIR}")"
CLUSTER_NAME="springboot-platform"
KEEP_CLUSTER=false

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-cluster)
      KEEP_CLUSTER=true
      shift
      ;;
    *)
      CLUSTER_NAME="$1"
      shift
      ;;
  esac
done

KUBECONFIG_PATH="${PROJECT_DIR}/var/${CLUSTER_NAME}.kubeconfig"
PID_FILE="${PROJECT_DIR}/var/worker.pid"
LOG_FILE="${PROJECT_DIR}/var/worker.log"

echo "Tearing down springboot-platform-app infrastructure..."

# Stop worker process
if [[ -f "${PID_FILE}" ]]; then
  PID=$(cat "${PID_FILE}")
  if kill -0 "${PID}" 2>/dev/null; then
    echo "Stopping worker (PID ${PID})..."
    kill "${PID}" 2>/dev/null || true
    sleep 2
    # Force kill if still running
    if kill -0 "${PID}" 2>/dev/null; then
      kill -9 "${PID}" 2>/dev/null || true
    fi
  fi
  rm -f "${PID_FILE}"
  echo "  Worker stopped."
fi

# Delete Kind cluster
if [[ "${KEEP_CLUSTER}" == "false" ]]; then
  if command -v kind >/dev/null 2>&1; then
    if kind get clusters 2>/dev/null | grep -q "^${CLUSTER_NAME}$"; then
      echo "Deleting Kind cluster '${CLUSTER_NAME}'..."
      kind delete cluster --name "${CLUSTER_NAME}"
      echo "  Cluster deleted."
    else
      echo "  Cluster '${CLUSTER_NAME}' not found (already deleted?)."
    fi
  fi

  # Clean up kubeconfig
  if [[ -f "${KUBECONFIG_PATH}" ]]; then
    rm -f "${KUBECONFIG_PATH}"
    echo "  Kubeconfig removed."
  fi
else
  echo "Keeping cluster '${CLUSTER_NAME}' (--keep-cluster specified)."
fi

# Clean up log file
if [[ -f "${LOG_FILE}" ]]; then
  rm -f "${LOG_FILE}"
  echo "  Log file removed."
fi

echo ""
echo "========================================="
echo "Teardown complete!"
echo "========================================="
if [[ "${KEEP_CLUSTER}" == "false" ]]; then
  echo "Cluster '${CLUSTER_NAME}' has been deleted."
else
  echo "Cluster '${CLUSTER_NAME}' is still running."
  echo "To delete it: kind delete cluster --name ${CLUSTER_NAME}"
fi
echo ""
echo "Don't forget to clean up ConfigHub:"
echo "  ./confighub-cleanup.sh"
echo "========================================="
