#!/usr/bin/env bash
# Create a Kind cluster for the springboot-platform-app example.
#
# Usage:
#   ./bin/create-cluster              # Create cluster with default name
#   ./bin/create-cluster my-cluster   # Create cluster with custom name
#
# Output:
#   - Kubeconfig saved to var/<cluster-name>.kubeconfig
#   - Export KUBECONFIG to use the cluster

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "${SCRIPT_DIR}")"
CLUSTER_NAME="${1:-springboot-platform}"

mkdir -p "${PROJECT_DIR}/var"

KUBECONFIG_PATH="${PROJECT_DIR}/var/${CLUSTER_NAME}.kubeconfig"

# Check prerequisites
command -v kind >/dev/null 2>&1 || {
  echo "error: kind CLI not found. Install from https://kind.sigs.k8s.io/" >&2
  exit 1
}

command -v kubectl >/dev/null 2>&1 || {
  echo "error: kubectl not found." >&2
  exit 1
}

# Check if cluster already exists
if kind get clusters 2>/dev/null | grep -q "^${CLUSTER_NAME}$"; then
  echo "Cluster '${CLUSTER_NAME}' already exists."
  echo "Kubeconfig: ${KUBECONFIG_PATH}"
  echo ""
  echo "To use: export KUBECONFIG=${KUBECONFIG_PATH}"
  exit 0
fi

echo "Creating Kind cluster '${CLUSTER_NAME}'..."

kind create cluster \
  --name "${CLUSTER_NAME}" \
  --kubeconfig "${KUBECONFIG_PATH}" \
  --wait 60s

echo ""
echo "Waiting for nodes to be Ready..."
export KUBECONFIG="${KUBECONFIG_PATH}"
kubectl wait --for=condition=Ready nodes --all --timeout=60s

echo ""
echo "========================================="
echo "Kind cluster created!"
echo "========================================="
echo "Cluster:    ${CLUSTER_NAME}"
echo "Kubeconfig: ${KUBECONFIG_PATH}"
echo ""
echo "To use:"
echo "  export KUBECONFIG=${KUBECONFIG_PATH}"
echo ""
echo "Next steps:"
echo "  ./bin/build-image"
echo "  CUB_SPACE=springboot-infra ./bin/install-worker"
echo "========================================="
