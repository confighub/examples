apiVersion: confighub.com/v1alpha1
kind: Recipe
metadata:
  name: __CHAIN_NAME__
  labels:
    example: __EXAMPLE_NAME__
    chain: __PREFIX__
spec:
  component: backend
  pattern: ordered-clone-chain
  description: One materialized global-app chain showing clone = variant, link = upgrade path, bundle = published deployment artifact.
  layers:
    - name: base
      space: __BASE_SPACE__
      unit: __BASE_UNIT__
      revision: __BASE_REV__
      dataHash: __BASE_HASH__
      mutationDelta: original global-app backend manifest
    - name: region
      space: __REGION_SPACE__
      unit: __REGION_UNIT__
      revision: __REGION_REV__
      dataHash: __REGION_HASH__
      mutationDelta: set REGION=US and host=backend.us.demo.confighub.local
    - name: role
      space: __ROLE_SPACE__
      unit: __ROLE_UNIT__
      revision: __ROLE_REV__
      dataHash: __ROLE_HASH__
      mutationDelta: set ROLE=staging, replicas=2, LOG_LEVEL=info
    - name: recipe
      space: __RECIPE_SPACE__
      unit: __RECIPE_UNIT__
      revision: __RECIPE_REV__
      dataHash: __RECIPE_HASH__
      mutationDelta: set CHAT_TITLE to recipe-specific value
    - name: deployment
      space: __DEPLOY_SPACE__
      unit: __DEPLOY_UNIT__
      revision: __DEPLOY_REV__
      dataHash: __DEPLOY_HASH__
      mutationDelta: set namespace=cluster-a, CLUSTER env var, and deployment host
  publish:
    targetRef: __TARGET_REF__
    bundleHint: __BUNDLE_HINT__
    note: The bundle is the deployable output of the deployment unit's target, not the source of truth for the layer chain.
