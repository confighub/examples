#!/bin/bash

set -euo pipefail

CLUSTER_NAME=${1:-gitops-import-argo}
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
ARGOCD_HOST_PORT=${ARGOCD_HOST_PORT:-}

if [ -z "$ARGOCD_HOST_PORT" ] && [ -f "$PROJECT_DIR/var/argocd-host-port.txt" ]; then
    ARGOCD_HOST_PORT="$(cat "$PROJECT_DIR/var/argocd-host-port.txt")"
fi

ARGOCD_HOST_PORT=${ARGOCD_HOST_PORT:-9080}

export KUBECONFIG="$PROJECT_DIR/var/$CLUSTER_NAME.kubeconfig"

if [ ! -f "$KUBECONFIG" ]; then
    echo "Error: Kubeconfig not found at $KUBECONFIG"
    echo "Please run bin/create-cluster and bin/install-argocd first"
    exit 1
fi

echo "Applying healthy guestbook Applications for ArgoCD sync..."
kubectl apply -f "$PROJECT_DIR/fixtures/argocd/guestbook-apps.yaml"

echo ""
echo "Guestbook Applications applied!"
echo "ArgoCD will now reconcile the healthy guestbook paths."
echo ""
echo "View in UI: http://localhost:$ARGOCD_HOST_PORT"
echo "List apps:  kubectl get applications -n argocd"
