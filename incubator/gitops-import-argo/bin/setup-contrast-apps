#!/bin/bash

set -euo pipefail

CLUSTER_NAME=${1:-gitops-import-argo}
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

export KUBECONFIG="$PROJECT_DIR/var/$CLUSTER_NAME.kubeconfig"

if [ ! -f "$KUBECONFIG" ]; then
    echo "Error: Kubeconfig not found at $KUBECONFIG"
    echo "Please run bin/create-cluster and bin/install-argocd first"
    exit 1
fi

echo "Creating contrast namespaces..."
for ns in myapp-dev myapp-staging myapp-prod; do
    kubectl create namespace "$ns" --dry-run=client -o yaml | kubectl apply -f -
done

retry_apply() {
    local file=$1
    local attempt
    for attempt in 1 2 3; do
        if kubectl apply -f "$file"; then
            return 0
        fi
        if [ "$attempt" -lt 3 ]; then
            echo "Retrying apply for $file after transient failure..."
            sleep 5
        fi
    done
    return 1
}

echo "Applying ArgoCD-labeled brownfield fixtures..."
retry_apply "$PROJECT_DIR/fixtures/contrast/applications.yaml"
retry_apply "$PROJECT_DIR/fixtures/contrast/deployments.yaml"
retry_apply "$PROJECT_DIR/fixtures/contrast/statefulsets.yaml"
retry_apply "$PROJECT_DIR/fixtures/contrast/native.yaml"

echo "Applying real guestbook Applications for ArgoCD sync..."
retry_apply "$PROJECT_DIR/fixtures/argocd/guestbook-apps.yaml"

echo "Contrast fixtures applied."
echo "Check Applications with: kubectl get applications -n argocd"
echo "Check workloads with: kubectl get all -A"
