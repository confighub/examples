{
  "example_name": "springboot-platform-app",
  "proof_type": "structural+confighub-only+noop-targets",
  "stack": [
    "Spring Boot",
    "platform-rendered operational config",
    "ConfigHub authority",
    "upstream provenance"
  ],
  "service_name": "inventory-api",
  "mutates_confighub": false,
  "mutates_live_infra": false,
  "confighub_only": {
    "mutates_confighub": true,
    "mutates_live_infra": false,
    "setup": "./confighub-setup.sh",
    "cleanup": "./confighub-cleanup.sh",
    "verify": "./confighub-verify.sh",
    "spaces": [
      "inventory-api-dev",
      "inventory-api-stage",
      "inventory-api-prod"
    ]
  },
  "reads": [
    "upstream/app/pom.xml",
    "upstream/app/src/main/java/com/example/inventory/InventoryApiApplication.java",
    "upstream/app/src/main/java/com/example/inventory/api/InventoryController.java",
    "upstream/app/src/main/java/com/example/inventory/api/InventoryService.java",
    "upstream/app/src/main/java/com/example/inventory/api/InventoryItem.java",
    "upstream/app/src/main/java/com/example/inventory/api/InventorySummary.java",
    "upstream/app/src/main/resources/application.yaml",
    "upstream/app/src/main/resources/application-stage.yaml",
    "upstream/app/src/main/resources/application-prod.yaml",
    "upstream/app/src/test/java/com/example/inventory/api/InventoryControllerHttpTest.java",
    "upstream/app/src/test/java/com/example/inventory/api/InventoryControllerProdHttpTest.java",
    "upstream/platform/runtime-policy.yaml",
    "upstream/platform/slo-policy.yaml",
    "operational/configmap.yaml",
    "operational/deployment.yaml",
    "operational/service.yaml",
    "operational/field-routes.yaml",
    "confighub/inventory-api-dev.yaml",
    "confighub/inventory-api-stage.yaml",
    "confighub/inventory-api-prod.yaml"
  ],
  "writes": [],
  "behaviors": [
    {
      "name": "apply_here",
      "request": "Change feature.inventory.reservationMode in prod for a rollout.",
      "default_route": "apply_here",
      "owner": "app-team",
      "upstream_inputs": [
        "upstream/app/src/main/resources/application-prod.yaml"
      ],
      "operational_fields": [
        "ConfigMap/data/application-prod.yaml:feature.inventory.reservationMode"
      ],
      "confighub_proof": "Proven via set-env FEATURE_INVENTORY_RESERVATIONMODE=optimistic on the prod Deployment. Spring Boot relaxed binding maps this env var to feature.inventory.reservationMode. The running app reports the changed value via /api/inventory/summary."
    },
    {
      "name": "lift_upstream",
      "request": "Add Redis-backed caching to the service.",
      "default_route": "lift_upstream",
      "owner": "app-team",
      "upstream_inputs": [
        "upstream/app/pom.xml",
        "upstream/app/src/main/resources/application.yaml"
      ],
      "operational_fields": [
        "Deployment/spec/template/spec/containers[0]/env[CACHE_BACKEND]",
        "ConfigMap/data/application.yaml:spring.cache.type"
      ],
      "confighub_proof": "Not yet proven. Requires GitHub PR integration."
    },
    {
      "name": "block_or_escalate",
      "request": "Change spring.datasource.* or bypass the managed datasource boundary.",
      "default_route": "block_or_escalate",
      "owner": "platform-engineering",
      "upstream_inputs": [
        "upstream/platform/runtime-policy.yaml"
      ],
      "operational_fields": [
        "ConfigMap/data/application.yaml:spring.datasource.url",
        "Deployment/spec/template/spec/containers[0]/env[SPRING_DATASOURCE_URL]"
      ],
      "confighub_proof": "Not yet proven. Requires field-level policy enforcement in ConfigHub."
    }
  ],
  "success_looks_like": [
    "The preview explains authority vs provenance clearly.",
    "The upstream app includes HTTP-level tests for the inventory API.",
    "The three routed outcomes are visible in one app.",
    "ConfigHub-only spaces and units exist for dev, stage, and prod.",
    "The apply-here mutation is proven via FEATURE_INVENTORY_RESERVATIONMODE env var on the prod Deployment, and the running app reports the changed value."
  ]
}
