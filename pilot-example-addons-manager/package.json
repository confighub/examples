{
  "name": "add-on-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "add-on-manager": "./cli.mjs"
  },
  "scripts": {
    "start": "node server.mjs",
    "test": "node tests/app.test.mjs && node tests/auth-surface.test.mjs && node tests/cli.test.mjs",
    "cli": "node cli.mjs",
    "cli:preflight": "node cli.mjs preflight --json",
    "cli:map": "node cli.mjs map --json",
    "cli:findings": "node cli.mjs findings --json",
    "cli:verify": "node cli.mjs verify --json",
    "oauth:register": "node scripts/register-oauth-client.mjs",
    "oauth:smoke": "node scripts/oauth-smoke.mjs",
    "binding:check": "node scripts/binding-check.mjs",
    "verify": "node scripts/verify.mjs && npm test"
  },
  "engines": {
    "node": ">=18"
  }
}
